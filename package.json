{
  "name": "openapi-shape",
  "version": "0.2.0",
  "description": "Generate TypeScript declarations and API shapes from OpenAPI JSON",
  "keywords": [
    "codegen",
    "dts",
    "openapi",
    "openapi-typescript",
    "openapi3",
    "schema-to-typescript",
    "type-generation",
    "typed-api-client",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usings/openapi-shape.git"
  },
  "bin": {
    "openapi-shape": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./client": "./dist/client.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "lefthook install",
    "prepublishOnly": "npm run build",
    "release": "bumpp",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
