{
  "openapi": "3.1.0",
  "info": { "title": "Edge Cases", "version": "1.0.0" },
  "paths": {
    "/items": {
      "get": {
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Item" }
                }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}": {
      "get": {
        "parameters": [{ "name": "itemId", "in": "path", "schema": { "type": "integer" } }],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Item" }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "responses": {
          "200": { "description": "OK" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Item": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": ["string", "null"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "metadata": { "type": "object", "additionalProperties": { "type": "string" } },
          "kind": { "$ref": "#/components/schemas/ItemKind" }
        },
        "required": ["id", "name"]
      },
      "ItemKind": {
        "type": "string",
        "enum": ["book", "movie", "music"]
      },
      "Shape": {
        "oneOf": [
          { "$ref": "#/components/schemas/Circle" },
          { "$ref": "#/components/schemas/Square" }
        ]
      },
      "Circle": {
        "type": "object",
        "properties": {
          "radius": { "type": "number" }
        },
        "required": ["radius"]
      },
      "Square": {
        "type": "object",
        "properties": {
          "side": { "type": "number" }
        },
        "required": ["side"]
      },
      "Extended": {
        "allOf": [
          { "$ref": "#/components/schemas/Circle" },
          {
            "type": "object",
            "properties": { "color": { "type": "string" } },
            "required": ["color"]
          }
        ]
      },
      "NullableOld": {
        "type": "string",
        "nullable": true
      }
    }
  }
}
