{
  "openapi": "3.1.0",
  "info": { "title": "Discriminator", "version": "1.0.0" },
  "components": {
    "schemas": {
      "Cat": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "purr": { "type": "string" }
        },
        "required": ["purr"]
      },
      "Dog": {
        "type": "object",
        "properties": {
          "bark": { "type": "string" }
        },
        "required": ["bark"]
      },
      "Animal": {
        "oneOf": [
          { "$ref": "#/components/schemas/Cat" },
          { "$ref": "#/components/schemas/Dog" }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "cat": "#/components/schemas/Cat",
            "dog": "#/components/schemas/Dog"
          }
        }
      },
      "Car": {
        "type": "object",
        "properties": { "wheels": { "type": "integer" } }
      },
      "Truck": {
        "type": "object",
        "properties": { "payload": { "type": "integer" } }
      },
      "Vehicle": {
        "oneOf": [
          { "$ref": "#/components/schemas/Car" },
          { "$ref": "#/components/schemas/Truck" }
        ],
        "discriminator": { "propertyName": "type" }
      }
    }
  },
  "paths": {
    "/animal": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Animal" } }
            }
          }
        }
      }
    }
  }
}
