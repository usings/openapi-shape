{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "import", "jsdoc", "vitest"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "vitest/require-to-throw-message": "off"
  },
  "env": {
    "builtin": true
  }
}
